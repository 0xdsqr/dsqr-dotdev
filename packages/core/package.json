{
  "name": "@dsqr-dotdev/core",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "auth:generate": "bunx @better-auth/cli generate --config src/auth/auth-cli.ts --output ../db/src/auth-schema.ts",
    "build": "bun run scripts/build.ts",
    "clean": "git clean -xdf dist node_modules"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./auth": {
      "import": "./dist/esm/auth/index.js",
      "types": "./dist/types/auth/index.d.ts"
    },
    "./api": {
      "import": "./dist/esm/api/index.js",
      "types": "./dist/types/api/index.d.ts"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "types": "./dist/types/*.d.ts"
    }
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.34",
    "@dsqr-dotdev/tsconfig": "workspace:*",
    "@types/pg": "^8.15.6",
    "bun-types": "latest",
    "typescript": "5.8.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@dsqr-dotdev/db": "workspace:*",
    "@trpc/server": "^11.7.1",
    "better-auth": "^1.3.34",
    "drizzle-orm": "^0.44.7",
    "resend": "^6.4.0",
    "superjson": "^2.2.5",
    "zod": "^4.1.12"
  }
}
