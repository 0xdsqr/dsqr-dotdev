{
  "name": "@dsqr-dotdev/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./auth": {
      "import": "./dist/esm/auth/index.js",
      "types": "./dist/types/auth/index.d.ts"
    },
    "./admin": {
      "import": "./dist/esm/api/admin.js",
      "types": "./dist/types/api/admin.d.ts"
    },
    "./api": {
      "import": "./dist/esm/api/index.js",
      "types": "./dist/types/api/index.d.ts"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "types": "./dist/types/*.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "clean": "git clean -xdf dist node_modules",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1094.0",
    "@dsqr-dotdev/database": "0.0.1",
    "@dsqr-dotdev/observability": "0.0.1",
    "@trpc/server": "11.18.0",
    "better-auth": "1.6.25",
    "drizzle-orm": "0.45.2",
    "effect": "3.22.0",
    "resend": "6.18.0",
    "superjson": "2.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@dsqr-dotdev/tsconfig": "0.0.1",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0"
  }
}
