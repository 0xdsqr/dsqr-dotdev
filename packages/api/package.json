{
  "name": "@dsqr-dotdev/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./auth": {
      "import": "./dist/esm/auth/index.js",
      "types": "./dist/types/auth/index.d.ts"
    },
    "./api": {
      "import": "./dist/esm/api/index.js",
      "types": "./dist/types/api/index.d.ts"
    },
    "./*": {
      "import": "./dist/esm/*.js",
      "types": "./dist/types/*.d.ts"
    }
  },
  "scripts": {
    "auth:generate": "better-auth generate --config src/auth/auth-cli.ts --output ../database/src/auth-schema.ts",
    "build": "node ../../scripts/build-package.mjs",
    "clean": "git clean -xdf dist node_modules",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.958.0",
    "@dsqr-dotdev/database": "0.0.0",
    "@trpc/server": "^11.7.1",
    "better-auth": "1.4.21",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.0",
    "resend": "^6.4.0",
    "superjson": "^2.2.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@dsqr-dotdev/tsconfig": "0.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6"
  }
}
