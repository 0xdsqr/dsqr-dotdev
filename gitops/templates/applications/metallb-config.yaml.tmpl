# Generated by `nix run .#gitopsGenerateApplications`.
# Cluster-specific MetalLB runtime objects live beside the MetalLB values overlay.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: metallb-config
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
  labels:
    app.kubernetes.io/instance: metallb-config
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: metallb-config
    app.kubernetes.io/part-of: cluster-networking
    homelab.dev/owner: platform
    homelab.dev/tier: platform-addon
spec:
  project: platform
  source:
    repoURL: ${VALUES_REPO_URL}
    targetRevision: ${VALUES_TARGET_REVISION}
    path: gitops/manifests/metallb/overlays/${CLUSTER_NAME}
  destination:
    server: ${DESTINATION_SERVER}
    namespace: metallb-system
  syncPolicy:
    automated:
      enabled: false
      prune: false
      selfHeal: false
    retry:
      limit: 5
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 3m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
