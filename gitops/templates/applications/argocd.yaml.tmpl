# Generated by `nix run .#gitopsGenerateApplications`.
# Argo CD self-management stays manual during migration so controller upgrades are deliberate.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: argocd
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    homelab.dev/chart: argo-cd
    homelab.dev/chart-repository: https://argoproj.github.io/argo-helm
    homelab.dev/chart-version: 9.5.2
    homelab.dev/values-common-file: gitops/manifests/argocd/base/values-common.yaml
    homelab.dev/values-overlay-file: gitops/manifests/argocd/overlays/homelab/values-overrides.yaml
  labels:
    app.kubernetes.io/instance: argocd
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: argocd
    app.kubernetes.io/part-of: dsqr-gitops
    app.kubernetes.io/version: 9.5.2
    homelab.dev/owner: platform
    homelab.dev/tier: gitops
spec:
  project: platform
  sources:
    - repoURL: https://argoproj.github.io/argo-helm
      chart: argo-cd
      targetRevision: 9.5.2
      helm:
        releaseName: argocd
        valueFiles:
          - ${VALUES_REF}/gitops/manifests/argocd/base/values-common.yaml
          - ${VALUES_REF}/gitops/manifests/argocd/overlays/homelab/values-overrides.yaml
    - repoURL: ${VALUES_REPO_URL}
      targetRevision: ${VALUES_TARGET_REVISION}
      ref: values
  destination:
    server: ${DESTINATION_SERVER}
    namespace: ${ARGOCD_NAMESPACE}
  syncPolicy:
    automated:
      enabled: false
      prune: false
      selfHeal: false
    retry:
      limit: 3
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 2m
    syncOptions:
      - ApplyOutOfSyncOnly=true
