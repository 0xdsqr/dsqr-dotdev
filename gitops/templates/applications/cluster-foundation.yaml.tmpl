# Generated by `nix run .#gitopsGenerateApplications`.
# Cluster-scoped namespaces and workload AppProjects reconcile before platform add-ons.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: cluster-foundation
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "0"
  labels:
    app.kubernetes.io/instance: cluster-foundation
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: cluster-foundation
    app.kubernetes.io/part-of: dsqr-gitops
    homelab.dev/owner: platform
    homelab.dev/tier: gitops
spec:
  project: bootstrap
  source:
    repoURL: ${VALUES_REPO_URL}
    targetRevision: ${VALUES_TARGET_REVISION}
    path: ${VALUES_OVERLAY_DIR}
  destination:
    server: ${DESTINATION_SERVER}
    namespace: ${ARGOCD_NAMESPACE}
  syncPolicy:
    automated:
      enabled: true
      prune: true
      selfHeal: true
    retry:
      limit: 5
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 3m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
      - PruneLast=true
