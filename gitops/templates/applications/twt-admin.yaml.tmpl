# Generated by `nix run .#gitopsGenerateApplications`.
# Cluster-specific values are loaded through the ref-only values source below.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: twt-admin
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "4"
    homelab.dev/hostname: admin.tastingswithtay.com
  labels:
    app.kubernetes.io/instance: twt-admin
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: twt-admin
    app.kubernetes.io/part-of: tastingswithtay
    homelab.dev/owner: twt
    homelab.dev/tier: application
spec:
  project: twt
  sources:
    - repoURL: https://github.com/0xdsqr/tastingswithtay.git
      targetRevision: refs/heads/master
      path: helm/tastingswithtay-admin
      helm:
        releaseName: twt-admin
        valueFiles:
          - values-prod.yaml
          - ${VALUES_REF}/${VALUES_COMMON_FILE}
          - ${VALUES_REF}/${VALUES_OVERLAY_FILE}
    - repoURL: ${VALUES_REPO_URL}
      targetRevision: ${VALUES_TARGET_REVISION}
      ref: values
  destination:
    server: ${DESTINATION_SERVER}
    namespace: twt
  syncPolicy:
    automated:
      enabled: true
      prune: true
      selfHeal: true
    retry:
      limit: 3
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 2m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
      - PruneLast=true
