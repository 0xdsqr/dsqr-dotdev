# Generated by `nix run .#gitopsGenerateApplications`.
# Prefer cluster-specific overrides as Kustomize patches in this directory's kustomization.yaml.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: cilium
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
    homelab.dev/chart: cilium
    homelab.dev/chart-repository: https://helm.cilium.io/
    homelab.dev/chart-version: 1.19.1
    homelab.dev/values-common-file: ${VALUES_COMMON_FILE}
    homelab.dev/values-overlay-file: ${VALUES_OVERLAY_FILE}
  labels:
    app.kubernetes.io/instance: cilium
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: cilium
    app.kubernetes.io/part-of: cluster-networking
    app.kubernetes.io/version: 1.19.1
    homelab.dev/owner: platform
    homelab.dev/tier: platform-addon
spec:
  project: platform
  sources:
    - repoURL: https://helm.cilium.io/
      chart: cilium
      targetRevision: 1.19.1
      helm:
        releaseName: cilium
        valueFiles:
          - ${VALUES_REF}/${VALUES_COMMON_FILE}
          - ${VALUES_REF}/${VALUES_OVERLAY_FILE}
    - repoURL: ${VALUES_REPO_URL}
      targetRevision: ${VALUES_TARGET_REVISION}
      ref: values
  destination:
    server: ${DESTINATION_SERVER}
    namespace: kube-system
  ignoreDifferences:
    # Cilium was originally installed by Pulumi. Ignore Argo's tracking
    # annotation until a deliberate ownership handoff is performed.
    - group: '*'
      kind: '*'
      jsonPointers:
        - /metadata/annotations/argocd.argoproj.io~1tracking-id
    # Cilium renders these Helm-generated certs non-idempotently, so the
    # desired Secret data changes on render even when live Cilium is healthy.
    - kind: Secret
      name: cilium-ca
      namespace: kube-system
      jsonPointers:
        - /data
    - kind: Secret
      name: hubble-server-certs
      namespace: kube-system
      jsonPointers:
        - /data
  syncPolicy:
    automated:
      enabled: false
      prune: false
      selfHeal: false
    retry:
      limit: 3
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 2m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
      - RespectIgnoreDifferences=true
