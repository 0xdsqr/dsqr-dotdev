# Generated by `nix run .#gitopsGenerateApplications`.
# Day-two Argo CD secrets and ingress reconcile after their controllers are healthy.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: argocd-config
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "3"
  labels:
    app.kubernetes.io/instance: argocd-config
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: argocd-config
    app.kubernetes.io/part-of: argocd
    homelab.dev/owner: platform
    homelab.dev/tier: gitops
spec:
  project: bootstrap
  source:
    repoURL: ${VALUES_REPO_URL}
    targetRevision: ${VALUES_TARGET_REVISION}
    path: gitops/manifests/argocd/overlays/${CLUSTER_NAME}
  destination:
    server: ${DESTINATION_SERVER}
    namespace: ${ARGOCD_NAMESPACE}
  syncPolicy:
    automated:
      enabled: true
      prune: true
      selfHeal: true
    retry:
      limit: 5
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 3m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
      - PruneLast=true
