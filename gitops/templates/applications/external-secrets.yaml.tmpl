# Generated by `nix run .#gitopsGenerateApplications`.
# External Secrets Operator is manual during first Vault adoption so CRD/controller rollout is deliberate.
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: external-secrets
  namespace: ${ARGOCD_NAMESPACE}
  annotations:
    argocd.argoproj.io/sync-wave: "2"
  labels:
    app.kubernetes.io/instance: external-secrets
    app.kubernetes.io/managed-by: argocd
    app.kubernetes.io/name: external-secrets
    app.kubernetes.io/part-of: cluster-secrets
    app.kubernetes.io/version: 2.6.0
    homelab.dev/owner: platform
    homelab.dev/tier: platform-addon
spec:
  project: platform
  sources:
    - repoURL: https://charts.external-secrets.io
      chart: external-secrets
      targetRevision: 2.6.0
      helm:
        releaseName: external-secrets
        valueFiles:
          - ${VALUES_REF}/${VALUES_COMMON_FILE}
          - ${VALUES_REF}/${VALUES_OVERLAY_FILE}
    - repoURL: ${VALUES_REPO_URL}
      targetRevision: ${VALUES_TARGET_REVISION}
      ref: values
  destination:
    server: ${DESTINATION_SERVER}
    namespace: external-secrets
  syncPolicy:
    automated:
      enabled: false
      prune: false
      selfHeal: false
    retry:
      limit: 3
      refresh: true
      backoff:
        duration: 20s
        factor: 2
        maxDuration: 2m
    syncOptions:
      - ApplyOutOfSyncOnly=true
      - FailOnSharedResource=true
      - ServerSideApply=true
